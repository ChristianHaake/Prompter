{
  "name": "prompter",
  "private": true,
  "version": "1.0.0",
  "description": "Browserbasierter Teleprompter für deine Pitches.",
  "license": "GPL-3.0-only",
  "homepage": "https://prompter.haak3.de",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChristianHaake/Prompter.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist playwright-report test-results",
    "test": "vitest run tests/*.test.ts",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "audit": "npm audit --omit=dev",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run audit && npm run build && npm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/dompurify": "^3.0.5",
    "@types/marked": "^5.0.2",
    "@types/node": "20.19.43",
    "eslint": "^10.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "dompurify": "3.4.11",
    "marked": "^18.0.5"
  }
}
